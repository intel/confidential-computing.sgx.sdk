index 000000000..695ddac57
--- /dev/null
+++ b/.sgx_patched
@@ -0,0 +1 @@
+sgx_protobuf
\ No newline at end of file
diff --git a/CMakeLists.txt b/CMakeLists.txt
index fd4a1eade..acf6cf934 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -18,6 +18,13 @@ if(CMAKE_CXX_STANDARD AND CMAKE_CXX_STANDARD LESS 17)
   message(FATAL_ERROR "The minimum supported C++ standard is C++ 17")
 endif()
 
+#for SGX
+if(SGX)
+  add_definitions(-DPB_ENABLE_SGX)
+  set(SGX_PROGRAM_SEARCH_PATH)
+  LIST(APPEND CMAKE_PROGRAM_PATH  "/usr/local/bin/"  ${SGX_PROGRAM_SEARCH_PATH} ...)
+endif()
+
 if(protobuf_DEPRECATED_CMAKE_SUBDIRECTORY_USAGE)
   if(CMAKE_PROJECT_NAME STREQUAL "protobuf")
     get_filename_component(CMAKE_SOURCE_DIR ${CMAKE_SOURCE_DIR} DIRECTORY)
@@ -259,13 +266,27 @@ else (MSVC)
   set(LIB_PREFIX)
 endif (MSVC)
 
-include_directories(
-  ${ZLIB_INCLUDE_DIRECTORIES}
-  ${protobuf_BINARY_DIR}
-  # Support #include-ing other top-level directories, i.e. upb_generator.
-  ${protobuf_SOURCE_DIR}
-  ${protobuf_BINARY_DIR}/src
-  ${protobuf_SOURCE_DIR}/src)
+if(SGX)
+  include_directories(
+    ${protobuf_BINARY_DIR}
+    ${protobuf_SOURCE_DIR}/src
+    ${protobuf_SOURCE_DIR}/../../../common/inc/internal
